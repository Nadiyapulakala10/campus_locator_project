rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Connections
    match /connections/{doc} {
      allow read, write: if request.auth != null;
    }

    // Connection Requests
    match /connection_requests/{doc} {
      allow read, write: if request.auth != null;
    }

    // Email OTPs — public read/write (for unauthenticated OTP verification)
    match /email_otps/{doc} {
      allow read, write: if true;
    }

    // Chats — only participants can read/write
    match /chats/{chatId} {
      allow read, write: if request.auth != null
        && request.auth.uid in resource.data.participants;

      // Messages inside a chat
      match /messages/{msgId} {
        allow read, write: if request.auth != null;
      }
    }

    // Calls (WebRTC signaling)
    match /calls/{callId} {
      allow read, write: if request.auth != null;

      match /callerCandidates/{c} {
        allow read, write: if request.auth != null;
      }

      match /calleeCandidates/{c} {
        allow read, write: if request.auth != null;
      }
    }

  }
}